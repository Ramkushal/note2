{
  "name": "a-note",
  "private": true,
  "version": "1.0.0",
  "description": "A PDF annotation viewer with highlights, comments, and Markdown export.",
  "author": "Ram kushal",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "cross-env ELECTRON=1 tsc -b && cross-env ELECTRON=1 vite build && electron-packager . \"A'note\" --icon=build/icons/icon.ico --platform=win32 --arch=x64 --out=release --overwrite --no-prune --ignore=src --ignore=node_modules\\/.* --ignore=.git --ignore=eb_log.txt --ignore=eb_debug.log",
    "installer": "cross-env ELECTRON=1 npm run build && cross-env ELECTRON=1 electron-builder --win"
  },
  "build": {
    "appId": "com.Ram kushal.a-note",
    "productName": "A'note",
    "copyright": "Copyright © 2026 Ram kushal",
    "npmRebuild": false,
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!src",
      "!website"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "A'note"
    }
  },
  "dependencies": {
    "@types/uuid": "^11.0.0",
    "idb": "^8.0.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.624",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron/packager": "^19.0.5",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
